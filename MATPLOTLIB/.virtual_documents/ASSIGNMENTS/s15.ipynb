pip install ydata-profiling


import pandas as pd
from ydata_profiling import ProfileReport


df = pd.read_csv("spotify.csv")
profile = ProfileReport(df, title="Spotify Top 100 Songs Report")
profile.to_file("spotify_report.html")


pip install sweetviz


import sweetviz as sv

mumbai = pd.read_csv("mumbai.csv")
delhi = pd.read_csv("delhi.csv")
report = sv.compare(
    [mumbai, "Mumbai"],
    [delhi, "Delhi"]
)
report.show_html("comparison_report.html")


pip install dtale


import dtale
import pandas as pd
df = pd.read_csv("myntra.csv")

d = dtale.show(df)

d.open_browser()


df = pd.read_csv("bookmyshow.csv")

# Group by genre and calculate average box office collection
result = (
    df.groupby("genre")["box_office_collection"]
      .mean()
      .sort_values(ascending=False)
      .reset_index()
)
print(result)


