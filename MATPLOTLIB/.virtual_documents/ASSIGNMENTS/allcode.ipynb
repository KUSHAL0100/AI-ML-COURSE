x = [1,2,3,4]
y = [10,20,15,25]

plt.figure(figsize=(8,6))

# Line Plot
plt.subplot(2,2,1)
plt.plot(x, y)
plt.title("Line Plot")
plt.xlabel("X Values")
plt.ylabel("Y Values")

# Bar Chart
plt.subplot(2,2,2)
plt.bar(x, y)
plt.title("Bar Chart")
plt.xlabel("Categories")
plt.ylabel("Values")

# Scatter Plot
plt.subplot(2,2,3)
plt.scatter(x, y)
plt.title("Scatter Plot")
plt.xlabel("X Values")
plt.ylabel("Y Values")

# Pie Chart
students = [25,30,20,25]
courses = ["Python","Java","C++","Web"]

