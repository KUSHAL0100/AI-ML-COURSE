days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]
screen_time = [45,50,60,55,70,80,65]
likes = [20,18,30,25,35,40,28]

plt.figure(figsize=(10,5))

# First Plot
plt.subplot(1,2,1)
plt.plot(days, screen_time, marker='o')
plt.title("Instagram Screen Time")
plt.xlabel("Days")
plt.ylabel("Minutes")

# Second Plot
plt.subplot(1,2,2)
plt.bar(days, likes)
plt.title("Posts Liked")
plt.xlabel("Days")
plt.ylabel("Likes")

plt.tight_layout()

plt.savefig("social_media_usage.png")
plt.show()








